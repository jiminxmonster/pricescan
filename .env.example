# PriceScan deployment example
# Copy to .env on the server and fill real values when needed.

DATA_DIR=/app/data
DATABASE_PATH=/app/data/pricescan.db

# Per-source daily external request safety limits (Asia/Seoul reset)
NAVER_DAILY_REQUEST_LIMIT=200
DANAWA_DAILY_REQUEST_LIMIT=100
ENURI_DAILY_REQUEST_LIMIT=60
